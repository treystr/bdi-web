---
import Button from '@components/ui/Button.astro';
import { Megaphone, Newspaper, CalendarDays, ChevronLeft, ChevronRight } from 'lucide-astro';
import {
    getPress,
    getPressSlug,
    getPressImageUrl,
    normalizePressType,
    type PressItem,
} from '@lib/directus';

export interface Props {
    content?: {
        title?: string;
        description?: string;
        button?: {
            text: string;
            link: string;
            variant?: 'primary' | 'secondary' | 'ghostLight' | 'ghostDark';
            size?: 'sm' | 'md' | 'lg' | 'xl' | 'xxl';
        };
    };
    fallbackImage?: ImageMetadata;
    limit?: number;
    autoAdvanceMs?: number;
}

type ImageMetadata = { src: string; width: number; height: number; format: string };

const {
    content,
    fallbackImage,
    limit = 6,
    autoAdvanceMs = 6000,
} = Astro.props;

const pressResult = await getPress();
const allItems: PressItem[] = pressResult.data ?? [];
const pressItems = allItems.filter(item => item.Cover).slice(0, limit);
const hasPressItems = pressItems.length > 0;

interface Slide {
    imageUrl: string;
    title: string;
    type: ReturnType<typeof normalizePressType>;
    slug: string;
    excerpt: string;
}

const slides: Slide[] = pressItems.map(item => ({
    imageUrl: getPressImageUrl(item.Cover, 1600) ?? '',
    title: item.Title,
    type: normalizePressType(item.type),
    slug: getPressSlug(item),
    excerpt: item.Subtitle ?? '',
}));

const typeLabels: Record<string, string> = {
    'press-release': 'Press Release',
    'in-the-news': 'In the News',
    'events': 'Event',
};

const carouselId = `press-hero-${Math.random().toString(36).slice(2, 11)}`;
---

<section
    class="press-hero"
    id={carouselId}
    data-press-hero
    data-auto-advance={autoAdvanceMs}
    aria-label="Press highlights"
    style="position:relative;width:100%;overflow:hidden;"
>
    {/* ===== DESKTOP: full-viewport immersive layout (hidden on mobile) ===== */}
    {hasPressItems && (
        <div class="press-hero__desktop">
            <div class="press-hero__slides">
                {slides.map((slide, i) => (
                    <div
                        class:list={['press-hero__slide', { 'is-active': i === 0 }]}
                        data-slide-index={i}
                        data-layout="desktop"
                        aria-hidden={i !== 0 ? 'true' : 'false'}
                    >
                        <img
                            src={slide.imageUrl}
                            alt=""
                            class="press-hero__image"
                            loading={i === 0 ? 'eager' : 'lazy'}
                            decoding={i === 0 ? 'sync' : 'async'}
                        />
                        <div class="press-hero__overlay" />
                    </div>
                ))}
            </div>

            <div class="press-hero__caption">
                {slides.map((slide, i) => (
                    <a
                        href={`/press/${slide.slug}`}
                        class:list={['press-hero__caption-item', { 'is-active': i === 0 }]}
                        data-caption-index={i}
                        data-layout="desktop"
                    >
                        {slide.type && (
                            <span class="press-hero__badge">
                                {slide.type === 'press-release' && <Megaphone size={14} />}
                                {slide.type === 'in-the-news' && <Newspaper size={14} />}
                                {slide.type === 'events' && <CalendarDays size={14} />}
                                <span>{typeLabels[slide.type] ?? ''}</span>
                            </span>
                        )}
                        <h2 class="press-hero__slide-title">{slide.title}</h2>
                        {slide.excerpt && (
                            <p class="press-hero__slide-excerpt">{slide.excerpt}</p>
                        )}
                    </a>
                ))}
            </div>

            {slides.length > 1 && (
                <Fragment>
                    <button class="press-hero__arrow press-hero__arrow--prev" data-hero-prev aria-label="Previous slide">
                        <ChevronLeft size={28} />
                    </button>
                    <button class="press-hero__arrow press-hero__arrow--next" data-hero-next aria-label="Next slide">
                        <ChevronRight size={28} />
                    </button>
                </Fragment>
            )}
        </div>
    )}

    {/* ===== MOBILE: card layout with full image + info below (hidden on desktop) ===== */}
    {hasPressItems && (
        <div class="press-hero__mobile">
            {slides.map((slide, i) => (
                <a
                    href={`/press/${slide.slug}`}
                    class:list={['press-hero__mobile-slide', { 'is-active': i === 0 }]}
                    data-mobile-slide-index={i}
                    aria-hidden={i !== 0 ? 'true' : 'false'}
                >
                    <div class="press-hero__mobile-image-wrap">
                        <img
                            src={slide.imageUrl}
                            alt=""
                            class="press-hero__mobile-image"
                            loading={i === 0 ? 'eager' : 'lazy'}
                            decoding={i === 0 ? 'sync' : 'async'}
                        />
                    </div>
                    <div class="press-hero__mobile-info">
                        {slide.type && (
                            <span class="press-hero__badge">
                                {slide.type === 'press-release' && <Megaphone size={12} />}
                                {slide.type === 'in-the-news' && <Newspaper size={12} />}
                                {slide.type === 'events' && <CalendarDays size={12} />}
                                <span>{typeLabels[slide.type] ?? ''}</span>
                            </span>
                        )}
                        <h2 class="press-hero__mobile-title">{slide.title}</h2>
                        {slide.excerpt && (
                            <p class="press-hero__mobile-excerpt">{slide.excerpt}</p>
                        )}
                    </div>
                </a>
            ))}
        </div>
    )}

    {/* ===== FALLBACK: static hero when CMS unavailable ===== */}
    {!hasPressItems && (
        <div class="press-hero__fallback" style="position:absolute;inset:0;">
            <div class="press-hero__slide is-active" style="position:absolute;inset:0;opacity:1;">
                {fallbackImage ? (
                    <img
                        src={fallbackImage.src}
                        alt=""
                        class="press-hero__image"
                        style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;"
                        loading="eager"
                    />
                ) : (
                    <div class="press-hero__image press-hero__image--placeholder" style="position:absolute;inset:0;width:100%;height:100%;" />
                )}
                <div class="press-hero__overlay" style="position:absolute;inset:0;z-index:1;" />
            </div>
        </div>
    )}

    {!hasPressItems && (
        <div class="press-hero__content" style="position:absolute;top:50%;left:50%;transform:translate(-50%,-60%);z-index:10;text-align:center;width:90%;max-width:48rem;">
            {content?.title && (
                <h1 class="press-hero__title" style="color:white;">{content.title}</h1>
            )}
            {content?.description && (
                <p class="press-hero__description" style="color:rgba(255,255,255,0.9);">{content.description}</p>
            )}
            {content?.button && (
                <div class="press-hero__cta">
                    <Button
                        href={content.button.link}
                        variant={content.button.variant || 'primary'}
                        size={content.button.size || 'xl'}
                    >
                        {content.button.text}
                    </Button>
                </div>
            )}
        </div>
    )}

    {/* ===== DOT INDICATORS + PROGRESS (shared) ===== */}
    {hasPressItems && slides.length > 1 && (
        <nav class="press-hero__dots" aria-label="Slide navigation">
            {slides.map((_, i) => (
                <button
                    class:list={['press-hero__dot', { 'is-active': i === 0 }]}
                    data-dot-index={i}
                    aria-label={`Go to slide ${i + 1}`}
                    aria-current={i === 0 ? 'true' : 'false'}
                />
            ))}
        </nav>
    )}

    {hasPressItems && slides.length > 1 && (
        <div class="press-hero__progress">
            <div class="press-hero__progress-bar" data-progress-bar />
        </div>
    )}
</section>

<style>
    /* =============================================
       BASE / SECTION
       ============================================= */
    .press-hero {
        position: relative;
        width: 100%;
        background: #0a0a0a;
    }

    /* =============================================
       DESKTOP LAYOUT  (>=768 px)
       Immersive full-viewport with overlay text
       ============================================= */
    .press-hero__desktop {
        display: none;
    }

    @media (min-width: 768px) {
        .press-hero {
            height: 100vh;
            height: 100dvh;
        }

        .press-hero__desktop {
            display: block;
            position: absolute;
            inset: 0;
        }

        .press-hero__mobile {
            display: none !important;
        }
    }

    .press-hero__slides {
        position: absolute;
        inset: 0;
    }

    .press-hero__slide {
        position: absolute;
        inset: 0;
        opacity: 0;
        transition: opacity 0.8s ease-in-out;
        will-change: opacity;
    }

    .press-hero__slide.is-active {
        opacity: 1;
        z-index: 1;
    }

    .press-hero__image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
    }

    .press-hero__image--placeholder {
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
    }

    .press-hero__overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
            to top,
            rgba(0, 0, 0, 0.75) 0%,
            rgba(0, 0, 0, 0.35) 40%,
            rgba(0, 0, 0, 0.15) 70%,
            rgba(0, 0, 0, 0.25) 100%
        );
        z-index: 1;
    }

    /* Desktop caption (bottom-left overlay) */
    .press-hero__caption {
        position: absolute;
        bottom: 5rem;
        left: 2rem;
        z-index: 10;
        max-width: 36rem;
    }

    .press-hero__caption-item {
        display: none;
        flex-direction: column;
        gap: 0.5rem;
        text-decoration: none;
        color: white;
        transition: opacity 0.3s ease;
    }

    .press-hero__caption-item:hover {
        opacity: 0.85;
    }

    .press-hero__caption-item.is-active {
        display: flex;
    }

    .press-hero__slide-title {
        font-size: clamp(1.125rem, 2.5vw, 1.5rem);
        font-weight: 700;
        line-height: 1.3;
        color: white;
        text-shadow: 0 1px 8px rgba(0, 0, 0, 0.4);
    }

    .press-hero__slide-excerpt {
        font-size: 0.9rem;
        color: rgba(255, 255, 255, 0.75);
        line-height: 1.5;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    /* Desktop arrows */
    .press-hero__arrow {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        z-index: 15;
        display: none;
        align-items: center;
        justify-content: center;
        width: 3rem;
        height: 3rem;
        border: none;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.12);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        color: white;
        cursor: pointer;
        transition: background 0.3s ease, transform 0.3s ease;
        opacity: 0;
    }

    .press-hero:hover .press-hero__arrow {
        opacity: 1;
    }

    .press-hero__arrow:hover {
        background: rgba(255, 255, 255, 0.25);
        transform: translateY(-50%) scale(1.1);
    }

    .press-hero__arrow--prev { left: 1.5rem; }
    .press-hero__arrow--next { right: 1.5rem; }

    @media (min-width: 768px) {
        .press-hero__arrow {
            display: flex;
        }
    }

    /* =============================================
       MOBILE LAYOUT  (<768 px)
       Full-width image at natural ratio + info card
       ============================================= */
    .press-hero__mobile {
        position: relative;
    }

    .press-hero__mobile-slide {
        display: none;
        flex-direction: column;
        text-decoration: none;
        color: white;
        opacity: 0;
        transition: opacity 0.5s ease-in-out;
    }

    .press-hero__mobile-slide.is-active {
        display: flex;
        opacity: 1;
    }

    .press-hero__mobile-image-wrap {
        position: relative;
        width: 100%;
        aspect-ratio: 16 / 10;
        overflow: hidden;
        background: #111;
    }

    .press-hero__mobile-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
    }

    .press-hero__mobile-info {
        display: flex;
        flex-direction: column;
        gap: 0.625rem;
        padding: 1.25rem 1.25rem 3.5rem;
        background: linear-gradient(to bottom, #111 0%, #0a0a0a 100%);
    }

    .press-hero__mobile-title {
        font-size: 1.2rem;
        font-weight: 700;
        line-height: 1.35;
        color: white;
    }

    .press-hero__mobile-excerpt {
        font-size: 0.875rem;
        color: rgba(255, 255, 255, 0.65);
        line-height: 1.55;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    @media (min-width: 768px) {
        .press-hero__mobile {
            display: none !important;
        }
    }

    /* =============================================
       SHARED: Badge, Dots, Progress
       ============================================= */
    .press-hero__badge {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        padding: 0.25rem 0.625rem;
        background: rgba(255, 255, 255, 0.15);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        border-radius: 0.25rem;
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: rgba(255, 255, 255, 0.9);
        width: fit-content;
    }

    .press-hero__dots {
        position: absolute;
        bottom: 1rem;
        left: 50%;
        transform: translateX(-50%);
        z-index: 15;
        display: flex;
        gap: 0.5rem;
        align-items: center;
    }

    .press-hero__dot {
        width: 0.5rem;
        height: 0.5rem;
        border: none;
        border-radius: 9999px;
        background: rgba(255, 255, 255, 0.4);
        cursor: pointer;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        padding: 0;
    }

    .press-hero__dot:hover {
        background: rgba(255, 255, 255, 0.7);
    }

    .press-hero__dot.is-active {
        width: 2rem;
        background: var(--color-primary, #f7931a);
    }

    .press-hero__progress {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: rgba(255, 255, 255, 0.1);
        z-index: 15;
    }

    .press-hero__progress-bar {
        height: 100%;
        width: 0%;
        background: var(--color-primary, #f7931a);
        transition: width 0.1s linear;
    }

    .press-hero__progress-bar.is-animating {
        transition: width linear;
    }

    @media (max-width: 767px) {
        .press-hero__dots {
            gap: 0.4rem;
        }

        .press-hero__dot {
            width: 0.6rem;
            height: 0.6rem;
        }

        .press-hero__dot.is-active {
            width: 2rem;
        }
    }

    /* =============================================
       FALLBACK (no CMS data)
       ============================================= */
    .press-hero__fallback {
        position: absolute;
        inset: 0;
    }

    .press-hero__content {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -60%);
        z-index: 10;
        text-align: center;
        width: 90%;
        max-width: 48rem;
        pointer-events: none;
    }

    .press-hero__title {
        font-size: clamp(2rem, 5vw, 3.75rem);
        font-weight: 800;
        color: white;
        line-height: 1.1;
        margin-bottom: 1rem;
        text-shadow: 0 2px 20px rgba(0, 0, 0, 0.5);
        letter-spacing: -0.02em;
    }

    .press-hero__description {
        font-size: clamp(1rem, 2vw, 1.25rem);
        color: rgba(255, 255, 255, 0.9);
        line-height: 1.6;
        margin-bottom: 2rem;
        text-shadow: 0 1px 10px rgba(0, 0, 0, 0.4);
    }

    .press-hero__cta {
        pointer-events: auto;
    }

    /* Fallback needs full viewport height */
    .press-hero:has(.press-hero__fallback) {
        height: 100vh;
        height: 100dvh;
    }
</style>

<script>
    function initPressHero(container: HTMLElement) {
        const desktopSlides = container.querySelectorAll<HTMLElement>('[data-slide-index]');
        const desktopCaptions = container.querySelectorAll<HTMLElement>('[data-caption-index]');
        const mobileSlides = container.querySelectorAll<HTMLElement>('[data-mobile-slide-index]');
        const dots = container.querySelectorAll<HTMLButtonElement>('[data-dot-index]');
        const progressBar = container.querySelector<HTMLElement>('[data-progress-bar]');
        const prevBtn = container.querySelector<HTMLButtonElement>('[data-hero-prev]');
        const nextBtn = container.querySelector<HTMLButtonElement>('[data-hero-next]');

        const totalSlides = Math.max(desktopSlides.length, mobileSlides.length);
        if (totalSlides <= 1) return;

        const autoAdvanceMs = parseInt(container.dataset.autoAdvance ?? '6000', 10);
        let current = 0;
        let timer: ReturnType<typeof setInterval> | null = null;
        let isPaused = false;

        function goTo(index: number) {
            if (index === current) return;

            desktopSlides[current]?.classList.remove('is-active');
            desktopSlides[current]?.setAttribute('aria-hidden', 'true');
            desktopCaptions[current]?.classList.remove('is-active');
            mobileSlides[current]?.classList.remove('is-active');
            mobileSlides[current]?.setAttribute('aria-hidden', 'true');
            dots[current]?.classList.remove('is-active');
            dots[current]?.setAttribute('aria-current', 'false');

            current = ((index % totalSlides) + totalSlides) % totalSlides;

            desktopSlides[current]?.classList.add('is-active');
            desktopSlides[current]?.setAttribute('aria-hidden', 'false');
            desktopCaptions[current]?.classList.add('is-active');
            mobileSlides[current]?.classList.add('is-active');
            mobileSlides[current]?.setAttribute('aria-hidden', 'false');
            dots[current]?.classList.add('is-active');
            dots[current]?.setAttribute('aria-current', 'true');

            resetProgress();
        }

        function next() {
            goTo(current + 1);
        }

        function prev() {
            goTo(current - 1);
        }

        function resetProgress() {
            if (!progressBar) return;
            progressBar.classList.remove('is-animating');
            progressBar.style.width = '0%';

            void progressBar.offsetWidth;
            progressBar.classList.add('is-animating');
            progressBar.style.transitionDuration = `${autoAdvanceMs}ms`;
            progressBar.style.width = '100%';
        }

        function startAutoAdvance() {
            stopAutoAdvance();
            resetProgress();
            timer = setInterval(() => {
                if (!isPaused) {
                    next();
                }
            }, autoAdvanceMs);
        }

        function stopAutoAdvance() {
            if (timer) {
                clearInterval(timer);
                timer = null;
            }
        }

        dots.forEach((dot) => {
            dot.addEventListener('click', () => {
                const idx = parseInt(dot.dataset.dotIndex ?? '0', 10);
                goTo(idx);
                startAutoAdvance();
            });
        });

        prevBtn?.addEventListener('click', () => {
            prev();
            startAutoAdvance();
        });

        nextBtn?.addEventListener('click', () => {
            next();
            startAutoAdvance();
        });

        container.addEventListener('mouseenter', () => {
            isPaused = true;
            if (progressBar) {
                progressBar.classList.remove('is-animating');
            }
        });

        container.addEventListener('mouseleave', () => {
            isPaused = false;
            if (progressBar) {
                resetProgress();
            }
        });

        let touchStartX = 0;
        const SWIPE_THRESHOLD = 50;

        container.addEventListener('touchstart', (e: TouchEvent) => {
            touchStartX = e.changedTouches[0].screenX;
        }, { passive: true });

        container.addEventListener('touchend', (e: TouchEvent) => {
            const touchEndX = e.changedTouches[0].screenX;
            const diff = touchStartX - touchEndX;
            if (Math.abs(diff) > SWIPE_THRESHOLD) {
                if (diff > 0) {
                    next();
                } else {
                    prev();
                }
                startAutoAdvance();
            }
        }, { passive: true });

        container.addEventListener('keydown', (e: KeyboardEvent) => {
            if (e.key === 'ArrowLeft') {
                prev();
                startAutoAdvance();
            } else if (e.key === 'ArrowRight') {
                next();
                startAutoAdvance();
            }
        });

        startAutoAdvance();
    }

    function initAllPressHeroes() {
        document.querySelectorAll<HTMLElement>('[data-press-hero]').forEach(initPressHero);
    }

    document.addEventListener('DOMContentLoaded', initAllPressHeroes);
    document.addEventListener('astro:page-load', initAllPressHeroes);
</script>
