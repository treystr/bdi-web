---
import { Image } from 'astro:assets';
import logo from '../assets/logo_rect2.png';
interface Props {
    variant?: 'header' | 'footer' | 'dark';
}

const { variant = 'header' } = Astro.props;

// Determine the appropriate CSS class based on the variant
const getLogoClass = () => {
    switch (variant) {
        case 'header':
            return 'text-header-logo hover:text-primary';
        case 'footer':
            return 'text-footer-logo hover:text-primary';
        case 'dark':
            return 'text-body-base hover:text-primary';
        default:
            return 'text-body-base hover:text-primary';
    }
};
---

<a href="/" class:list={['logo transition-colors duration-200 flex items-center whitespace-nowrap', getLogoClass()]}>
    <Image 
        src={logo} 
        alt="Bitcoin District Initiative Logo" 
        class="h-10 sm:h-11 lg:h-12 w-auto flex-shrink-0 transition-all duration-300" 
    />
</a>
