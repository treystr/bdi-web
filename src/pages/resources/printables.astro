---
export const prerender = false;

import Layout from '@layouts/Layout.astro';
import PageHeader from '@components/sections/PageHeader.astro';
import FilterButtons from '@components/ui/FilterButtons.astro';
import {
  getDocuments,
  getDocumentAssetUrl,
  getDocumentPreviewImageUrl,
  getDocumentPreviewUrl,
  normalizeDocumentType,
} from '@lib/directus';

const seoTitle = 'Printables';
const seoDescription =
  'Download and share printable resources from the Bitcoin District Initiative.';

const pageHeaderContent = {
  title: 'Printables',
  description:
    'Download brochures and flyers to help educate your community about the Bitcoin circular economy in Washington, DC.',
};

const documentsResult = await getDocuments();
const cmsError = documentsResult.error;

const documentCards = (documentsResult.data ?? [])
  .map((item) => {
    const fileUrl = getDocumentAssetUrl(item.file);
    if (!fileUrl) return null;

    const normalizedType = normalizeDocumentType(item.type);
    const filterType = normalizedType ?? 'other';
    const typeLabel =
      normalizedType === 'brochure'
        ? 'Brochure'
        : normalizedType === 'flyer'
          ? 'Flyer'
          : 'Other';

    return {
      id: item.id,
      name: item.name,
      description: item.description ?? '',
      fileUrl,
      previewUrl: getDocumentPreviewImageUrl(item.preview_image, 850) ?? getDocumentPreviewUrl(item.file, 850),
      filterType,
      typeLabel,
    };
  })
  .filter(Boolean) as Array<{
    id: number;
    name: string;
    description: string;
    fileUrl: string;
    previewUrl: string | null;
    filterType: 'brochure' | 'flyer' | 'other';
    typeLabel: string;
  }>;

const hasBrochures = documentCards.some((item) => item.filterType === 'brochure');
const hasFlyers = documentCards.some((item) => item.filterType === 'flyer');
const hasOther = documentCards.some((item) => item.filterType === 'other');

const filters = [
  { id: 'all', label: 'All', value: null },
  ...(hasBrochures ? [{ id: 'brochure', label: 'Brochures', value: 'brochure' }] : []),
  ...(hasFlyers ? [{ id: 'flyer', label: 'Flyers', value: 'flyer' }] : []),
  ...(hasOther ? [{ id: 'other', label: 'Other', value: 'other' }] : []),
];
---

<Layout title={seoTitle} description={seoDescription}>
  <PageHeader
    title={pageHeaderContent.title}
    description={pageHeaderContent.description}
    background="base"
  />

  {documentCards.length > 0 && <FilterButtons filters={filters} defaultFilter="all" />}

  <section class="py-xsmall bg-background">
    <div class="site-container--content mx-auto px-4">
      {cmsError ? (
        <p class="text-body-base/60 italic">
          Printables are temporarily unavailable. Please check back soon.
        </p>
      ) : documentCards.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-5 gap-4">
          {documentCards.map((item, index) => (
            <div
              class="printable-card-slot"
              data-filter-item
              data-filter-type={item.filterType}
              data-aos="fade-up"
              data-aos-delay={index * 80}
            >
              <a
                href={item.fileUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="printable-card printable-card-desktop group"
              >
                <div class="printable-card-image-wrap" data-preview-container>
                  {item.previewUrl ? (
                    <img
                      src={item.previewUrl}
                      alt=""
                      loading="lazy"
                      decoding="async"
                      fetchpriority="low"
                      class="printable-card-image"
                      data-printable-preview
                    />
                  ) : null}

                  <div class="printable-card-fallback" data-printable-fallback={!item.previewUrl}>
                    <svg viewBox="0 0 24 24" aria-hidden="true" class="printable-file-icon">
                      <path
                        fill="currentColor"
                        d="M14 2H7a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8zm0 1.5L18.5 8H14zM7 4h6v5h5v11H7zm2.25 8.25h6.5v1.5h-6.5zm0 3.25h6.5V17h-6.5z"
                      />
                    </svg>
                    <span class="printable-fallback-text">Preview unavailable</span>
                  </div>
                </div>

                <div class="p-3">
                  <span class="printable-type-chip">{item.typeLabel}</span>
                  <h2 class="mt-2 text-sm font-bold text-heading group-hover:text-primary transition-colors duration-300 line-clamp-2">
                    {item.name}
                  </h2>
                  <p class="mt-1 text-xs text-body-base/80 line-clamp-3">{item.description}</p>
                </div>
              </a>

              <a
                href={item.fileUrl}
                target="_blank"
                rel="noopener noreferrer"
                class={`printable-row group ${index % 2 === 0 ? 'bg-white hover:bg-gray-50' : 'bg-gray-50 hover:bg-gray-100'}`}
              >
                <div class="printable-row-thumb" data-preview-container>
                  {item.previewUrl ? (
                    <img
                      src={item.previewUrl}
                      alt=""
                      loading="lazy"
                      decoding="async"
                      fetchpriority="low"
                      class="h-full w-full object-cover"
                      data-printable-preview
                    />
                  ) : null}
                  <div class="printable-card-fallback printable-row-fallback" data-printable-fallback={!item.previewUrl}>
                    <svg viewBox="0 0 24 24" aria-hidden="true" class="printable-file-icon">
                      <path
                        fill="currentColor"
                        d="M14 2H7a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8zm0 1.5L18.5 8H14zM7 4h6v5h5v11H7zm2.25 8.25h6.5v1.5h-6.5zm0 3.25h6.5V17h-6.5z"
                      />
                    </svg>
                  </div>
                </div>
                <div class="min-w-0 flex-1">
                  <span class="printable-type-chip">{item.typeLabel}</span>
                  <h2 class="mt-1 text-base font-bold text-heading group-hover:text-primary transition-colors duration-300 line-clamp-2">
                    {item.name}
                  </h2>
                  <p class="mt-1 text-sm text-body-base/80 line-clamp-2">{item.description}</p>
                </div>
              </a>
            </div>
          ))}
        </div>
      ) : (
        <p class="text-body-base/60 italic">
          No printable resources are available yet. Check back soon.
        </p>
      )}
    </div>
  </section>
</Layout>

<style>
  .printable-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border: 1px solid color-mix(in oklab, var(--color-heading) 15%, transparent);
    border-radius: 1rem;
    background: var(--color-background);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.04);
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }

  .printable-card-slot {
    width: 100%;
  }

  .printable-card-desktop {
    max-width: 14rem;
    margin: 0 auto;
    border: 1.5px solid color-mix(in oklab, var(--color-heading) 28%, transparent);
    display: none;
  }

  .printable-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 14px 30px rgba(0, 0, 0, 0.08);
    border-color: color-mix(in oklab, var(--color-primary) 35%, transparent);
  }

  .printable-card-image-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 8.5/11;
    background: linear-gradient(
      135deg,
      color-mix(in oklab, var(--color-primary) 8%, white),
      color-mix(in oklab, var(--color-background) 95%, white)
    );
    border-bottom: 1px solid color-mix(in oklab, var(--color-heading) 12%, transparent);
    overflow: hidden;
  }

  .printable-card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .group:hover .printable-card-image {
    transform: scale(1.03);
  }

  .printable-card-fallback {
    position: absolute;
    inset: 0;
    display: none;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 0.5rem;
    color: color-mix(in oklab, var(--color-heading) 65%, white);
  }

  .printable-card-fallback[data-printable-fallback='true'] {
    display: flex;
  }

  .printable-file-icon {
    width: 2.5rem;
    height: 2.5rem;
    opacity: 0.8;
  }

  .printable-fallback-text {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .printable-type-chip {
    display: inline-flex;
    align-items: center;
    border-radius: 9999px;
    padding: 0.3rem 0.7rem;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    background: color-mix(in oklab, var(--color-primary) 12%, transparent);
    color: var(--color-primary);
  }

  .printable-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    width: 100%;
    padding: 1rem 1.25rem;
    transition: background-color 0.2s ease;
  }

  .printable-row-thumb {
    height: 4.75rem;
    width: 3.5rem;
    border-radius: 0.375rem;
    overflow: hidden;
    border: 1px solid color-mix(in oklab, var(--color-heading) 18%, transparent);
    background: color-mix(in oklab, var(--color-heading) 6%, white);
    flex-shrink: 0;
    position: relative;
  }

  .printable-row-fallback .printable-file-icon {
    width: 1.25rem;
    height: 1.25rem;
  }

  @media (min-width: 768px) {
    .printable-card-desktop {
      display: flex;
    }

    .printable-row {
      display: none;
    }
  }
</style>

<script>
  function initPrintablePreviewFallbacks() {
    document.querySelectorAll<HTMLImageElement>('[data-printable-preview]').forEach((image) => {
      if (image.dataset.previewInitialized === 'true') return;
      image.dataset.previewInitialized = 'true';

      image.addEventListener('error', () => {
        const wrapper = image.closest('[data-preview-container]');
        if (!wrapper) return;
        const fallback = wrapper.querySelector<HTMLElement>('[data-printable-fallback]');
        if (!fallback) return;

        image.style.display = 'none';
        fallback.dataset.printableFallback = 'true';
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPrintablePreviewFallbacks);
  } else {
    initPrintablePreviewFallbacks();
  }

  document.addEventListener('astro:page-load', initPrintablePreviewFallbacks);
</script>
