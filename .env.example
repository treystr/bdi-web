# =============================================================================
# BDI Astro Site - Environment Variables
# =============================================================================

# --- Directus CMS ---

# Server-side URL (internal Docker network, used during SSR)
DIRECTUS_URL=http://directus:8055

# Client-side / public URL (used for asset URLs rendered in HTML)
# DEVELOPMENT:
PUBLIC_DIRECTUS_URL=http://localhost:8055
# PRODUCTION (uncomment):
# PUBLIC_DIRECTUS_URL=https://cms.bitcoindistrict.org

# Server-side auth token (optional, for reading non-public collections)
DIRECTUS_STATIC_TOKEN=

# --- Site ---

# Public site URL (used for sitemap, canonical URLs, etc.)
PUBLIC_SITE_URL=http://localhost:4321
# PRODUCTION (uncomment):
# PUBLIC_SITE_URL=https://bitcoindistrictinitiative.org
